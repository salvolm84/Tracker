{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Electronics Application Engineering",
  "version": "0.2.1",
  "identifier": "com.salvolm.tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Electronics Application Engineering",
        "width": 1440,
        "height": 980,
        "minWidth": 1120,
        "minHeight": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["resources/lists/*"]
  }
}
